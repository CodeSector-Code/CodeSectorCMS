@model IEnumerable<CodeSectorCMS.Domain.Account>

@section HeadContent {

}
    <h5 class="mb-4"><a asp-action="Create">Create New User</a></h5>
    <div class="table-responsive text-nowrap">
        <table class="table card-table">
        <caption class="ms-4">
            List of Users <br /><br /><br />
        </caption>
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.User.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Email)</th>
                    <th>@Html.DisplayNameFor(model => model.Username)</th>
                    <th>Status</th>
                    <th>@Html.DisplayNameFor(model => model.DateCreated)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody class="table-border-bottom-0">
                @foreach (var item in Model) 
                {
                    <tr>
                        <td><i class="fab fa-angular fa-lg text-danger me-3"></i><strong>@Html.DisplayFor(modelItem => item.User.Name)</strong></td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>
                            <ul class="list-unstyled users-list m-0 avatar-group d-flex align-items-center">
                                <li data-bs-toggle="tooltip"
                                    data-popup="tooltip-custom"
                                    data-bs-placement="top"
                                    class="avatar avatar-xs pull-up"
                                    title=@Html.DisplayFor(modelItem => item.Username)>
                                    <img src="../assets/img/avatars/profilem.jpg" alt="Avatar" class="rounded-circle" />
                                </li>
                            </ul>
                        </td>
                        <td><span class="badge bg-label-primary me-1">Active</span></td>
                        <td>@Html.DisplayFor(modelItem => item.DateCreated)</td>
                        <td>
                        <div class="dropdown">
                          <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                            <i class="bx bx-dots-vertical-rounded"></i>
                          </button>
                          <div class="dropdown-menu">
                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@item.AccountID"><i class="bx bx-edit-alt me-1"></i> Edit</a>
                            <a class="dropdown-item" asp-action="Delete" asp-route-id="@item.AccountID"><i class="bx bx-trash me-1"></i> Delete</a>
                          </div>
                        </div>
                      </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>