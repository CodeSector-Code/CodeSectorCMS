@model IEnumerable<CodeSectorCMS.Domain.TrackMessage>

@section HeadContent {

}

<div class="table-responsive text-nowrap">
    <table class="table card-table">
        <caption class="ms-4">
            List of Emails <br /><br /><br />
        </caption>
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Receiver)</th>
                <th>@Html.DisplayNameFor(model => model.Subject)</th>
                <th>Owner</th>
                <th>@Html.DisplayNameFor(model => model.Company)</th>
                <th>@Html.DisplayNameFor(model => model.Sent)</th>
                <th>@Html.DisplayNameFor(model => model.Opened)</th>
                <th>@Html.DisplayNameFor(model => model.OpenCount)</th>
                <th>@Html.DisplayNameFor(model => model.DateCreated)</th>
                <th></th>
            </tr>
        </thead>
        <tbody class="table-border-bottom-0">
            @foreach (var item in Model)
            {
                <tr>
                    <td><i class="fab fa-angular fa-lg text-danger me-3"></i><strong>@Html.DisplayFor(modelItem => item.Receiver)</strong></td>
                    <td>@Html.DisplayFor(modelItem => item.Subject)</td>
                    <td>
                        <ul class="list-unstyled users-list m-0 avatar-group d-flex align-items-center">
                            <li data-bs-toggle="tooltip"
                                data-popup="tooltip-custom"
                                data-bs-placement="top"
                                class="avatar avatar-xs pull-up"
                                title="User who created campaign"> @* title=@Html.DisplayFor(modelItem => item.Username)> *@
                                <img src="../assets/img/avatars/profilem.jpg" alt="Avatar" class="rounded-circle" />
                            </li>
                        </ul>
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Company)</td>

                    @if (item.Sent)
                    {
                        <td><span class="badge bg-label-success me-1">Sent</span></td>
                    }
                    else
                    {
                        <td><span class="badge bg-label-danger me-1">Not Sent</span></td>
                    }
                    @if (item.Opened)
                    {
                        <td><span class="badge bg-label-success me-1">Opened</span></td>
                    }
                    else
                    {
                        <td><span class="badge bg-label-danger me-1">Not Opend</span></td>
                    }

                    @if (item.OpenCount > 0)
                    {
                        <td class="center-container"><span class="badge badge-center bg-label-success">@Html.DisplayFor(modelItem => item.OpenCount)</span></td>
                    }
                    else
                    {
                        <td class="center-container"><span class="badge badge-center bg-label-secondary">@Html.DisplayFor(modelItem => item.OpenCount)</span></td>
                    }

                    <td>@Html.DisplayFor(modelItem => item.DateCreated)</td>
                    <td>
                        <div class="dropdown">
                            <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                <i class="bx bx-dots-vertical-rounded"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a class="dropdown-item" asp-action="Delete" asp-route-id="@item.Id"><i class="bx bx-trash me-1"></i> Delete</a>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
