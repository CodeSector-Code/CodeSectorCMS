@model CodeSectorCMS.Domain.SubscriberGroup

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Details</title>
</head>
<body>

<div>
    <h4>SubscriberGroup</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
    </dl>

        @Html.Label("Subscribers:")

        <table>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Subscribers.First().Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Subscribers.First().Email)
                </th>
            </tr>

            @foreach (var item in Model.Subscribers)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Email)
                    </td>
                </tr>
            }

        </table>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.SubscriberGroupID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
</body>
</html>
